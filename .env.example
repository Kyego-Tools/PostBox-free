# ──────────────────────────────────────────────────────
#  PostBox — Environment Variables
# ──────────────────────────────────────────────────────


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  REQUIRED — Convex Project
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Your Convex project URL (Dashboard → Settings → URL)
# Example: https://happy-animal-123.convex.cloud
NEXT_PUBLIC_CONVEX_URL=

# Same slug but .convex.site (for OAuth callbacks)
# Example: https://happy-animal-123.convex.site
NEXT_PUBLIC_CONVEX_SITE_URL=

# Deploy key for automated setup (Dashboard → Settings → Deploy Keys → Generate)
# Example: prod:happy-animal-123|eyJ2...
CONVEX_DEPLOY_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  OPTIONAL — App Settings
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Public URL where the app is accessible (default: http://localhost:3000)
# Change this if you're behind a reverse proxy or custom domain
APP_URL=

# GitHub repo for update checks in the About page (format: username/repo-name)
# Example: elvisgasana/postbox
# Leave empty to disable the update checker
NEXT_PUBLIC_GITHUB_REPO=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  OPTIONAL — Platform Credentials
#  Add the platforms you want to connect.
#  You can leave these empty and add them later from
#  the Convex dashboard (Settings → Environment Variables).
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Facebook ──
# Create app at: https://developers.facebook.com/apps
# Permissions needed: pages_manage_posts, pages_read_engagement
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Instagram ──
# Uses the same Meta app as Facebook
# Permissions needed: instagram_basic, instagram_content_publish
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ── TikTok ──
# Create app at: https://developers.tiktok.com
# Products needed: Login Kit, Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Twitter / X ──
# Create app at: https://developer.x.com/en/portal
# OAuth 2.0 with PKCE, scopes: tweet.read, tweet.write, users.read, offline.access
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── Threads ──
# Uses the same Meta app as Facebook/Instagram
# Add the Threads API product to your Meta app
THREADS_APP_ID=
THREADS_APP_SECRET=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  REQUIRED — Vercel
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Vercel access token (vercel.com → Settings → Tokens → Create)
VERCEL_TOKEN=
